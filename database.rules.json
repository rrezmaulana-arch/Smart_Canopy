{
  "rules": {
    
    // ─── Sensor Nodes (ESP32 menulis, Web membaca) ────────────
    "sensors": {
      "hujan": {
        ".read": true,
        ".write": "auth != null"
      },
      "cahaya": {
        ".read": true,
        ".write": "auth != null"
      }
    },

    // ─── Kanopi (ESP32 & Web keduanya baca/tulis) ─────────────
    "canopy": {
      ".read": true,
      ".write": "auth != null"
    },

    // ─── Pengaturan (Web menulis, ESP32 membaca) ──────────────
    "settings": {
      ".read": true,
      ".write": "auth != null"
    },

    // ─── Heartbeat (ESP32 menulis tanpa auth via setTimestamp) ─
    "system": {
      ".read": true,
      ".write": true
    },

    // ─── Riwayat Data ─────────────────────────────────────────
    "Data_Historis": {
      ".read": true,
      ".write": "auth != null"
    }

  }
}
